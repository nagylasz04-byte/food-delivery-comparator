// ER diagram for food-delivery-comparator (Graphviz DOT)
// Nodes: Felhasznalo, Etel, Etterem, EtteremEtelInfo, EtteremKoltseg, Mentes

digraph ER {
  rankdir=LR;
  node [shape=record,fontname="Helvetica"];

  Felhasznalo [label="{Felhasznalo|id PK\nusername\nemail\n...}"];
  Etel [label="{Etel|id PK\nnev\nleiras\nkategoria\nkep_url}"];
  Etterem [label="{Etterem|id PK\nnev\ncim\nplatform\nplatform_url}"];
  EtteremEtelInfo [label="{EtteremEtelInfo|id PK\netel_id FK\netterem_id FK\nplatform\nar\nszallitas_ido}"];
  EtteremKoltseg [label="{EtteremKoltseg|id PK\netterem_id FK?\netel_id FK?\nplatform?\nkoltseg_tipus\nosszeg}"];
  Mentes [label="{Mentes|id PK\nfelhasznalo_id FK\netel_id FK\nletrehozva}"];

  // relationships
  Felhasznalo -> Mentes [label="1:N"];
  Etel -> EtteremEtelInfo [label="1:N"];
  Etterem -> EtteremEtelInfo [label="1:N"];
  Etterem -> EtteremKoltseg [label="1:N"];
  Etel -> EtteremKoltseg [label="1:N (optional)"];
  Etel -> Mentes [label="1:N"];
}
